# Database
DATABASE_URL=postgresql://...          # Neon Postgres connection string
DATABASE_URL_UNPOOLED=postgresql://... # Direct connection for migrations

# Auth (Better Auth)
BETTER_AUTH_SECRET=                    # 32+ char random string
BETTER_AUTH_URL=http://localhost:3000  # Full app URL

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bunny.net (Stream)
BUNNY_STREAM_API_KEY=                  # Your API Key
BUNNY_STREAM_LIBRARY_ID=               # Your Video Library ID
BUNNY_CDN_HOSTNAME=                    # Your CDN hostname (e.g., your-pull-zone.b-cdn.net)

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Trigger.dev
TRIGGER_SECRET_KEY=

# Hono API
HONO_API_URL=http://localhost:8787     # Local dev; Cloudflare Workers URL in prod

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
